# MyOriShop — production environment template.
#
# Copy to `.env.production` next to docker-compose.prod.yml ON THE SERVER, fill
# every CHANGE_ME, then `chmod 600 .env.production`. NEVER commit .env.production
# (only this .example is tracked). Both ori-app and ori-db read this same file.

# --- PostgreSQL (ori-db container) ---------------------------------------
POSTGRES_USER=myorishop
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=myorishop

# --- App -----------------------------------------------------------------
# Points at the ori-db container over the private ori-net (host = container name).
# The password here MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+psycopg://myorishop:CHANGE_ME_strong_db_password@ori-db:5432/myorishop

# Session-cookie signing key. Generate ONCE on the server, never reuse the sample:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Rotating this logs every browser session out.
SECRET_KEY=CHANGE_ME_run_secrets_token_hex_32

# Public HTTPS domain → cookie must carry the Secure flag. Keep true on the server.
SESSION_HTTPS_ONLY=true

# The startup VACUUM INTO backup is SQLite-only; disable it on PostgreSQL.
# Server backups are done separately with pg_dump.
BACKUP_ON_STARTUP=false

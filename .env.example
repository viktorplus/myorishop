# Path to the SQLite database file (relative to project root)
DB_PATH=data/myorishop.db

# Operator name recorded as created_by on every operation (audit trail)
OPERATOR_NAME=operator

# --- Optional identity/crypto overrides (leave empty to auto-persist) ---
# When these are empty the app generates and persists stable per-install values
# under data/ (data/secret_key, data/device_id) which is gitignored. Never
# commit real secret values.

# SECRET_KEY: signing key for session cookies. Leave empty to auto-persist a
# stable per-install key at data/secret_key (a restart must not log everyone out).
SECRET_KEY=

# DEVICE_ID: unique per-install identity for future sync. Leave empty to
# auto-persist a UUID at data/device_id (must be unique per install, never shared).
DEVICE_ID=

# Timezone used only for displaying timestamps (storage is always UTC)
DISPLAY_TZ=Europe/Moscow
